# Copy to .env in this directory (relay/x402-client) and set one option below.
# Never commit .env

# Option A: path to the JSON keypair file (from `solana-keygen new --outfile ...`)
# Run the client with cwd = this package directory, or use an absolute path.
RELAY_PAYER_KEYPAIR_PATH=./payer-wallet.json

# Option B: raw secret key as a JSON number array (same format as the file contents)
# RELAY_PAYER_SECRET_KEY=[1,2,3,...]
